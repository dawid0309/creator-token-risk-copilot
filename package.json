{
  "name": "creator-token-risk-copilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "tsc && tsc -p server/tsconfig.json && vite build",
